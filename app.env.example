APP_NAME=文衡工作台

ENVIRONMENT=production
CORS_ORIGINS=https://your-domain.example
ALLOW_USER_AI_CONFIG=false
ALLOW_PRIVATE_AI_ENDPOINTS=false

OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

POLISH_MODEL=replace-with-your-model
POLISH_API_KEY=replace-with-your-api-key
POLISH_BASE_URL=https://api.openai.com/v1

ENHANCE_MODEL=replace-with-your-model
ENHANCE_API_KEY=replace-with-your-api-key
ENHANCE_BASE_URL=https://api.openai.com/v1

EMOTION_MODEL=replace-with-your-model
EMOTION_API_KEY=replace-with-your-api-key
EMOTION_BASE_URL=https://api.openai.com/v1

COMPRESSION_MODEL=replace-with-your-model
COMPRESSION_API_KEY=replace-with-your-api-key
COMPRESSION_BASE_URL=https://api.openai.com/v1

MAX_CONCURRENT_USERS=3
MAX_CONCURRENT_AI_REQUESTS=3
DEFAULT_USAGE_LIMIT=10
DEFAULT_TASK_CONCURRENCY_LIMIT=1
SEGMENT_SKIP_THRESHOLD=15
HISTORY_COMPRESSION_THRESHOLD=5000
USE_STREAMING=false
API_REQUEST_INTERVAL=1
THINKING_MODE_ENABLED=false
THINKING_MODE_EFFORT=none
MAX_UPLOAD_FILE_SIZE_MB=20
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# Optional bcrypt hash. When set, it takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=
SECRET_KEY=replace-with-a-random-secret
